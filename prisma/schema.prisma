generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique(map: "User_username_key")
  email        String         @unique(map: "User_email_key")
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  bio          String?
  bookmarks    Bookmark[]
  comments     Comment[]
  watchHistory WatchHistory[]

  @@map("user")
}

model Comment {
  id            String   @id @default(cuid())
  userId        String
  malId         Int
  episodeNumber Int
  body          String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([malId, episodeNumber], map: "Comment_malId_episodeNumber_idx")
  @@index([userId], map: "Comment_userId_idx")
  @@map("comment")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  malId     Int
  title     String
  posterUrl String?
  score     Float?
  type      String?
  createdAt DateTime @default(now())
  status    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, malId], map: "Bookmark_userId_malId_key")
  @@index([userId], map: "Bookmark_userId_idx")
  @@map("bookmark")
}

model WatchHistory {
  id              String   @id @default(cuid())
  userId          String
  malId           Int
  animeTitle      String
  posterUrl       String?
  episodeNumber   Int
  episodeTitle    String?
  progressPercent Int      @default(0)
  watchedAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, malId, episodeNumber], map: "WatchHistory_userId_malId_episodeNumber_key")
  @@index([userId], map: "WatchHistory_userId_idx")
  @@map("watchhistory")
}

model AnimeSlugMapping {
  malId        Int      @id
  slug         String   @unique(map: "AnimeSlugMapping_slug_key")
  title        String
  lastVerified DateTime @default(now())
  createdAt    DateTime @default(now())

  @@map("animeslugmapping")
}

model CachedAnime {
  malId     Int      @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cachedanime")
}
